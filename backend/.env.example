# Environment Configuration (DO NOT COMMIT .env - use .env.example as template)

# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Admin Authentication (CHANGE IMMEDIATELY IN PRODUCTION)
ADMIN_PASSWORD=admin123

# Database
DB_PATH=./sagra.sqlite
ENABLE_WAL=true

# Backup
BACKUP_INTERVAL_MINUTES=15
BACKUP_PATH=./backups

# Idempotency
QR_IDEMPOTENCY_WINDOW_MINUTES=10

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# CORS (for PWA frontend on same LAN)
CORS_ORIGIN=*
